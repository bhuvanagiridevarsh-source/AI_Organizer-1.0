<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow Electron Framework (signed by Electron project) to load
       into an ad-hoc signed app. Required on macOS 26+. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Allow JIT compilation used by V8 (Node.js / Chromium) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Allow unsigned executable memory (needed by Electron/V8) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
